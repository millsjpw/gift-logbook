                                    "schema": {
                                        "type": "object",
                                        "properties": {
                                            "personId": {
                                                "type": "string"
                                            },
                                            "excludedPersonIds": {
                                                "type": "array",
                                                "items": {
                                                    "type": "string"
                                                }
                                            }
                                        },
                                        "required": [
                                            "personId",
                                            "excludedPersonIds"
                                        ]
                                    }
                                }
                            }
                        },
                        "responses": {
                            "204": {
                                "description": "No content"
                            }
                        }
                    }
                },
